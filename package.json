{
  "name": "tgvmax-engine",
  "version": "2.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "ingest": "node tgvmax-ingest.js",
    "encode": "node encode-binary.js",
    "build-stations": "node build-stations-json.js",
    "build": "npm run ingest && npm run encode && npm run build-stations",
    "start": "node --max-old-space-size=450 server.js",
    "start:full": "node --max-old-space-size=600 server-fusion.js"
  },
  "dependencies": {
    "node-fetch": "^2.6.7",
    "tar": "^7.5.19"
  }
}